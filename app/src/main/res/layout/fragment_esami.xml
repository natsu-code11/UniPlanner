<?xml version="1.0" encoding="utf-8"?>

<!-- ============================================================
     FILE: fragment_esami.xml
     POSIZIONE: app/src/main/res/layout/
     SCOPO: Layout della schermata Esami. Contiene la lista degli
            esami e la media voti in cima.
            Verrà completato dalla Persona 2.
     LEZIONE DI RIFERIMENTO: L10 (Layouts & UI), L13 (RecyclerView)
     ============================================================ -->


<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <TextView
        android:id="@+id/tvTitoloEsami"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Esami"
        android:textColor="@android:color/black"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMedia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Media: --"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp" />

    <Button
        android:id="@+id/btnAggiungiEsame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Aggiungi esame"
        android:textColor="@android:color/white"
        android:backgroundTint="@android:color/holo_blue_dark" />

    <Button
        android:id="@+id/btnTornaHome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Torna alla schermata principale"
        android:textColor="@android:color/white"
        android:backgroundTint="@android:color/holo_blue_dark"
        android:layout_marginTop="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewEsami"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="12dp" />

</LinearLayout>
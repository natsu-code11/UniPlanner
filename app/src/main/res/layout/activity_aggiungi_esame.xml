<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitoloFormEsame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aggiungi esame"
            android:textColor="@android:color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNomeEsame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="Nome esame"
            android:inputType="text"
            android:textColor="@android:color/black"
            android:textColorHint="@android:color/darker_gray"
            android:backgroundTint="@android:color/holo_blue_dark"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/etDataEsame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="Data appello, es. 2026-06-20"
            android:inputType="text"
            android:textColor="@android:color/black"
            android:textColorHint="@android:color/darker_gray"
            android:backgroundTint="@android:color/holo_blue_dark"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etCfuEsame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="CFU"
            android:inputType="number"
            android:textColor="@android:color/black"
            android:textColorHint="@android:color/darker_gray"
            android:backgroundTint="@android:color/holo_blue_dark"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etVotoEsame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:hint="Voto, lascia 0 se non sostenuto"
            android:inputType="number"
            android:textColor="@android:color/black"
            android:textColorHint="@android:color/darker_gray"
            android:backgroundTint="@android:color/holo_blue_dark"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvStatoLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stato esame"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <RadioGroup
            android:id="@+id/rgStatoEsame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbDaSostenere"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="Da sostenere"
                android:textColor="@android:color/black"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbSuperato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text="Superato"
                android:textColor="@android:color/black" />

        </RadioGroup>

        <Button
            android:id="@+id/btnSalvaEsame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Salva"
            android:textColor="@android:color/white"
            android:backgroundTint="@android:color/holo_blue_dark"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnEliminaEsame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Elimina"
            android:textColor="@android:color/white"
            android:backgroundTint="@android:color/holo_blue_dark"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>
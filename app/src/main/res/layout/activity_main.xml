<!-- ============================================================
     FILE: activity_main.xml
     POSIZIONE: app/src/main/res/layout/
     SCOPO: Layout principale con toolbar personalizzata che mostra
            il nome dell'app e la bottom navigation bar blu
            con i colori istituzionali della Parthenope.
     ============================================================ -->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- barra in alto con il nome dell'app -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/parthenope_blue"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- nome app e sottotitolo a sinistra -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UniPlanner"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBenvenuto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Organizza la tua università"
                android:textColor="@color/parthenope_gold"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- parthenope a destra -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parthenope"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="italic"
            android:alpha="0.8" />

    </LinearLayout>

    <!-- contenitore dove vengono caricati i Fragment -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- barra di navigazione in basso -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/parthenope_blue"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
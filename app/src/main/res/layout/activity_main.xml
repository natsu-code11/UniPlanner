<!-- ============================================================
     FILE: activity_main.xml
     POSIZIONE: app/src/main/res/layout/
     SCOPO: Layout principale con toolbar e contenitore Fragment.
            La navigazione avviene tramite le card della Home.
     ============================================================ -->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- barra in alto -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/parthenope_blue"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UniPlanner"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBenvenuto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Organizza la tua università"
                android:textColor="@color/parthenope_gold"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parthenope"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="italic"
            android:alpha="0.8" />

    </LinearLayout>

    <!-- contenitore Fragment -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>